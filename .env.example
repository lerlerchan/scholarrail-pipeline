# ScholarStack environment — copy to ~/scholarstack/.env (chmod 600)
# or run: python3 setup_keys.py  (interactive, hidden input)
# NEVER commit the real .env.

# --- LLM (DeepSeek) — drafting + entity extraction, PRD §4 ---
DEEPSEEK_API_KEY=sk-...
# LightRAG reads the same key under its own name:
LLM_BINDING=openai
LLM_BINDING_API_KEY=sk-...
LLM_BINDING_HOST=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash

# --- Embeddings (local Ollama) ---
# NOTE: Ollama model name is "bge-m3", NOT "BAAI/bge-m3" (HF name 404s)
EMBEDDING_BINDING=ollama
EMBEDDING_BINDING_HOST=http://localhost:11434
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIM=1024
# bge-m3 cold-load exceeds LightRAG's 60s default:
EMBEDDING_TIMEOUT=180

# --- LightRAG storage ---
WORKING_DIR=/home/YOUR_USER/scholarstack/rag_storage

# --- Literature search (free academic tiers) ---
SEMANTIC_SCHOLAR_API_KEY=
SCOPUS_API_KEY=

# --- CritiqueBot (Claude — adversarial reviewer, different family from generator) ---
ANTHROPIC_API_KEY=
